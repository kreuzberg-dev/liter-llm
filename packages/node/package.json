{
	"name": "@kreuzberg/liter-llm",
	"version": "1.4.0-rc.20",
	"description": "Universal LLM API client — 142+ providers, streaming, tool calling. Rust-powered with polyglot bindings.",
	"license": "MIT",
	"main": "index.js",
	"types": "index.d.ts",
	"repository": "https://github.com/kreuzberg-dev/liter-llm",
	"author": "Na'aman Hirschfeld",
	"keywords": [
		"llm",
		"api-client",
		"openai",
		"anthropic"
	],
	"files": [
		"index.js",
		"index.d.ts",
		"**/*.node"
	],
	"scripts": {
		"build": "napi build --release",
		"build:debug": "napi build",
		"build:ts": "echo 'No TypeScript wrapper to build'",
		"test": "node -e \"console.log('Add test command')\""
	},
	"napi": {
		"name": "liter-llm",
		"triples": [
			"x86_64-unknown-linux-gnu",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc"
		]
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.0.0"
	}
}
