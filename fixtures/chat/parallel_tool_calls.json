{
	"id": "parallel_tool_calls",
	"category": "chat",
	"description": "Chat request that results in parallel tool calls in the response",
	"api": {
		"method": "chat",
		"request": {
			"model": "gpt-4",
			"messages": [
				{
					"role": "user",
					"content": "What is the weather in NYC and London?"
				}
			],
			"tools": [
				{
					"type": "function",
					"function": {
						"name": "get_weather",
						"description": "Get the current weather for a given location",
						"parameters": {
							"type": "object",
							"properties": {
								"location": {
									"type": "string",
									"description": "The city name"
								}
							},
							"required": ["location"]
						}
					}
				}
			],
			"parallel_tool_calls": true
		},
		"mock_response": {
			"status": 200,
			"body": {
				"id": "chatcmpl-parallel001",
				"object": "chat.completion",
				"created": 1711000060,
				"model": "gpt-4",
				"choices": [
					{
						"index": 0,
						"message": {
							"role": "assistant",
							"content": null,
							"tool_calls": [
								{
									"id": "call_par001",
									"type": "function",
									"function": {
										"name": "get_weather",
										"arguments": "{\"location\": \"New York\"}"
									}
								},
								{
									"id": "call_par002",
									"type": "function",
									"function": {
										"name": "get_weather",
										"arguments": "{\"location\": \"London\"}"
									}
								}
							]
						},
						"finish_reason": "tool_calls"
					}
				],
				"usage": {
					"prompt_tokens": 65,
					"completion_tokens": 30,
					"total_tokens": 95
				}
			}
		}
	},
	"assertions": {
		"response_not_null": true,
		"choices_count": 1,
		"first_choice_has_tool_calls": true,
		"tool_calls_count": 2,
		"first_choice_finish_reason": "tool_calls"
	},
	"tags": ["chat", "tool-calling"],
	"skip": {}
}
