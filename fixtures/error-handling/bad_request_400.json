{
	"id": "bad_request_400",
	"category": "error-handling",
	"description": "400 Bad Request error when a parameter value is invalid",
	"api": {
		"method": "chat",
		"request": {
			"model": "gpt-4",
			"messages": [
				{
					"role": "user",
					"content": "Hello"
				}
			],
			"temperature": 5.0
		},
		"mock_response": {
			"status": 400,
			"body": {
				"error": {
					"message": "Invalid parameter: temperature must be between 0 and 2",
					"type": "invalid_request_error"
				}
			}
		}
	},
	"assertions": {
		"expect_success": false,
		"error_type": "BadRequest",
		"error_status_code": 400
	},
	"tags": ["error-handling"],
	"skip": {}
}
