{
	"id": "github_copilot_error_auth",
	"category": "error-handling",
	"description": "401 Authentication error returned by the GitHub Copilot API when the token is invalid or expired",
	"api": {
		"method": "chat",
		"request": {
			"model": "github_copilot/gpt-4o",
			"messages": [
				{
					"role": "user",
					"content": "Hello"
				}
			]
		},
		"mock_response": {
			"status": 401,
			"body": {
				"error": {
					"message": "Unauthorized: invalid or expired token",
					"type": "authentication_error",
					"code": "401"
				}
			}
		}
	},
	"assertions": {
		"error_type": "Authentication",
		"error_status_code": 401
	},
	"tags": ["error-handling", "github_copilot"],
	"skip": {}
}
