{
	"id": "github_copilot_chat",
	"category": "smoke",
	"description": "Basic chat completion via the GitHub Copilot provider (gpt-4o) with a single user message",
	"api": {
		"method": "chat",
		"request": {
			"model": "github_copilot/gpt-4o",
			"messages": [
				{
					"role": "user",
					"content": "Say hello in one word."
				}
			],
			"temperature": 0,
			"max_tokens": 16
		},
		"mock_response": {
			"status": 200,
			"body": {
				"id": "chatcmpl-copilot-001",
				"object": "chat.completion",
				"created": 1711000200,
				"model": "gpt-4o",
				"choices": [
					{
						"index": 0,
						"message": {
							"role": "assistant",
							"content": "Hello!"
						},
						"finish_reason": "stop"
					}
				],
				"usage": {
					"prompt_tokens": 12,
					"completion_tokens": 2,
					"total_tokens": 14
				}
			}
		}
	},
	"assertions": {
		"response_not_null": true,
		"choices_count": 1,
		"first_choice_content": "Hello!",
		"first_choice_finish_reason": "stop",
		"model": "gpt-4o",
		"usage_total_tokens": 14
	},
	"tags": ["smoke", "github_copilot"],
	"skip": {}
}
