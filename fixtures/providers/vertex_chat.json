{
	"id": "vertex_chat",
	"category": "smoke",
	"description": "Basic chat completion via the Google Vertex AI provider using the vertex_ai/ prefix for routing — verifies the prefix is stripped before dispatching and the Gemini response is normalised to the standard OpenAI chat completion shape",
	"api": {
		"method": "chat",
		"request": {
			"model": "vertex_ai/gemini-2.0-flash",
			"messages": [
				{
					"role": "user",
					"content": "Say hello in one word."
				}
			],
			"temperature": 0,
			"max_tokens": 16
		},
		"mock_response": {
			"status": 200,
			"body": {
				"id": "chatcmpl-vertex-001",
				"object": "chat.completion",
				"created": 1711000400,
				"model": "gemini-2.0-flash",
				"choices": [
					{
						"index": 0,
						"message": {
							"role": "assistant",
							"content": "Hello!"
						},
						"finish_reason": "stop"
					}
				],
				"usage": {
					"prompt_tokens": 10,
					"completion_tokens": 3,
					"total_tokens": 13
				}
			}
		}
	},
	"assertions": {
		"response_not_null": true,
		"choices_count": 1,
		"first_choice_content": "Hello!",
		"first_choice_finish_reason": "stop",
		"model": "gemini-2.0-flash",
		"usage_total_tokens": 13
	},
	"tags": ["smoke", "vertex_ai"],
	"skip": {}
}
