			"model": "gpt-4",
			"messages": [
				{
					"role": "user",
					"content": "Say done"
				}
			],
			"stream": true
		},
		"mock_response": {
			"status": 200,
			"stream_chunks": [
				{
					"id": "chatcmpl-done001",
					"object": "chat.completion.chunk",
