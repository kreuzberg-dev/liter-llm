					"model": "gpt-4",
					"choices": [
						{
							"index": 0,
							"delta": {
								"role": "assistant",
								"content": ""
							},
							"finish_reason": null
						}
					]
				},
				{
					"id": "chatcmpl-done001",
					"object": "chat.completion.chunk",
					"created": 1711000001,
					"model": "gpt-4",
					"choices": [
						{
							"index": 0,
							"delta": {
								"content": "Done"
							},
							"finish_reason": null
						}
					]
				},
				{
					"id": "chatcmpl-done001",
					"object": "chat.completion.chunk",
					"created": 1711000001,
					"model": "gpt-4",
					"choices": [
						{
							"index": 0,
							"delta": {},
							"finish_reason": "stop"
						}
