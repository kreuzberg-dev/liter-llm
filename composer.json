{
	"name": "kreuzberg/liter-lm",
	"description": "A universal LM API client with polyglot bindings \u2014 fast, type-safe, compiled",
	"version": "1.0.0-rc.1",
	"type": "php-ext",
	"license": "MIT",
	"keywords": ["llm", "openai", "api-client", "ai", "php8", "rust", "performance"],
	"homepage": "https://github.com/kreuzberg-dev/liter-lm",
	"support": {
		"issues": "https://github.com/kreuzberg-dev/liter-lm/issues",
		"source": "https://github.com/kreuzberg-dev/liter-lm"
	},
	"authors": [
		{
			"name": "Na'aman Hirschfeld",
			"email": "nhirschfeld@gmail.com",
			"role": "creator"
		}
	],
	"require": {
		"php": "^8.4"
	},
	"replace": {
		"ext-liter_lm_php": "*"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"phpstan/phpstan": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"LiterLm\\": "packages/php/src/"
		}
	},
	"scripts": {
		"test": "vendor/bin/phpunit"
	},
	"config": {
		"sort-packages": true
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"php-ext": {
		"extension-name": "liter_lm_php",
		"priority": 50,
		"support": {
			"source-url": "https://github.com/kreuzberg-dev/liter-lm",
			"download-url": "https://github.com/kreuzberg-dev/liter-lm/releases"
		}
	}
}
